---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar.jsx';
import Footer from '../../components/layout/Footer.jsx';
import PageHeader from '../../components/pages/PageHeader.jsx';
import ServiceDetail from '../../components/services/ServiceDetail.jsx';
import { services } from '../../data/services.js';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Layout
  title={`${service.title} | Bygg & Projektgruppen i Stockholm AB`}
  description={service.summary}
>
  <Navbar client:idle />
  <main>
    <PageHeader
      client:load
      eyebrow={`Tjänst ${service.idx}`}
      title={service.title}
      subtitle={service.summary}
      crumbs={[{ label: 'Tjänster', href: base + 'tjanster' }, { label: service.title }]}
    />
    <ServiceDetail client:visible slug={service.slug} />
  </main>
  <Footer />
</Layout>
