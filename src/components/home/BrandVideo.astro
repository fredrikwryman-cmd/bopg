---
// Dekorativ roterande 3D-logo. Videon har en svagt GRÅ bakgrund (uppmätt ur
// postern: topp ~#dcdcdc, botten ~#e5e5e5, lätt vertikal gradient). Sektionen
// bakom videon matchar exakt den grå gradienten så videorutan inte blir en
// synlig "låda", och tonar sedan ner till paper (#F7F5F1) mot nästa sektion.
// En mild vinjett-mask löser upp ev. kvarvarande nyansskillnad vid kanten.
// Reduced motion: video visas som standard, stillbild (poster) vid reduce.
const BASE = import.meta.env.BASE_URL;
---

<section class="brand-video" aria-hidden="true">
  <div class="brand-video-inner">
    <video
      class="brand-video-media"
      autoplay
      muted
      loop
      playsinline
      webkit-playsinline
      preload="metadata"
      poster={BASE + 'logo-3d-rotating-poster.jpg'}
    >
      <source src={BASE + 'logo-3d-rotating.mp4'} type="video/mp4" />
    </video>
    <img
      class="brand-video-still"
      src={BASE + 'logo-3d-rotating-poster.jpg'}
      alt="Bygg & Projektgruppen"
    />
  </div>
</section>

<style>
  .brand-video {
    /* Uppmätt grå videoton bakom videon (topp #dcdcdc -> botten #e5e5e5, samma
       riktning som videons egen gradient) sa videorutan smalter in utan "lada",
       och tonar sedan #e5e5e5 -> paper (#F7F5F1) mot nasta sektion sa ingen hard
       kant uppstar. Ovanfor moter mork hero som en ren, avsiktlig kontrast. */
    background: linear-gradient(to bottom, #dcdcdc 0%, #e5e5e5 62%, #F7F5F1 100%);
    padding: clamp(3.5rem, 8vw, 7rem) 1.5rem;
    display: flex;
    justify-content: center;
  }
  .brand-video-inner {
    width: 100%;
    max-width: clamp(320px, 78vw, 900px);
    margin: 0 auto;
  }
  .brand-video-media,
  .brand-video-still {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    /* Mild vinjett-mask (forsakring): mitten helt opak, ytterkanterna tonar ut till
       transparent sa ev. kvarvarande nyansskillnad mot den gra ytan loses upp.
       Konservativ radie (68% opak) sa den roterande loggan aldrig beskars. */
    -webkit-mask-image: radial-gradient(ellipse 92% 92% at 50% 50%, #000 68%, rgba(0,0,0,0) 100%);
    mask-image: radial-gradient(ellipse 92% 92% at 50% 50%, #000 68%, rgba(0,0,0,0) 100%);
  }
  /* Som standard: visa videon, dolj stillbilden. */
  .brand-video-still {
    display: none;
  }
  /* Reducerad rorelse: dolj videon, visa stillbilden. */
  @media (prefers-reduced-motion: reduce) {
    .brand-video-media {
      display: none;
    }
    .brand-video-still {
      display: block;
    }
  }
  @media (max-width: 600px) {
    .brand-video {
      padding-left: 1.1rem;
      padding-right: 1.1rem;
    }
    .brand-video-inner {
      max-width: 90vw;
    }
  }
</style>
