---
// Dekorativ roterande 3D-logo med ÄKTA transparens: VP9-alpha i WebM, med H.264
// mp4 som fallback (mp4:n har en jämn grå #e9e9e9 som matchar sektionsbakgrunden).
// Inga CSS-hack behövs längre (ingen mask, ingen ton-matchning/gradient-lada).
// Reduced motion: transparent poster-PNG i stället för spelande video.
const BASE = import.meta.env.BASE_URL;
---

<section class="brand-video" aria-hidden="true">
  <div class="brand-video-inner">
    <video
      class="brand-video-media"
      autoplay
      muted
      loop
      playsinline
      webkit-playsinline
      preload="metadata"
      width="1280"
      height="720"
      poster={BASE + 'logo-3d-rotating-poster.png'}
    >
      <source src={BASE + 'logo-3d-rotating.webm'} type="video/webm" />
      <source src={BASE + 'logo-3d-rotating.mp4'} type="video/mp4" />
    </video>
    <img
      class="brand-video-still"
      src={BASE + 'logo-3d-rotating-poster.png'}
      alt="Bygg & Projektgruppen"
      width="1280"
      height="720"
    />
  </div>
</section>

<style>
  .brand-video {
    /* Jamn gra (#e9e9e9 = exakt mp4-fallbackens ton) som tonar till paper (#F7F5F1)
       nedat. WebM-lasare ser sidbakgrunden rakt igenom loggan (akta alpha); mp4-
       fallback far en osynlig skarv (jamn gra mot jamn gra). Mork hero ovanfor. */
    background: linear-gradient(to bottom, #e9e9e9 0%, #e9e9e9 62%, #F7F5F1 100%);
    padding: clamp(3.5rem, 8vw, 7rem) 1.5rem;
    display: flex;
    justify-content: center;
  }
  .brand-video-inner {
    width: 100%;
    max-width: clamp(320px, 78vw, 900px);
    margin: 0 auto;
  }
  .brand-video-media,
  .brand-video-still {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }
  /* Som standard: visa videon, dolj stillbilden. */
  .brand-video-still {
    display: none;
  }
  /* Reducerad rorelse: dolj videon, visa den transparenta stillbilden. */
  @media (prefers-reduced-motion: reduce) {
    .brand-video-media {
      display: none;
    }
    .brand-video-still {
      display: block;
    }
  }
  @media (max-width: 600px) {
    .brand-video {
      padding-left: 1.1rem;
      padding-right: 1.1rem;
    }
    .brand-video-inner {
      max-width: 90vw;
    }
  }
</style>
