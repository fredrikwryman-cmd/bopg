---
// Dekorativ roterande 3D-logo (mp4). INGEN keying: en rejäl mjuk radial vinjett-
// mask tonar videons kanter till transparent så den (1) döljer AI-vattenstämpeln
// i nedre högra hörnet och (2) löser upp videorutan så ingen rektangel syns.
// Sektionsbakgrunden är satt till videons uppmätta bakgrundston (#d4d4d4) så det
// som skymtar genom fade-zonen smälter ihop, och tonar sedan till paper nedåt.
// Reduced motion: stillbild (poster) i stället för spelande video.
const BASE = import.meta.env.BASE_URL;
---

<section class="brand-video" aria-hidden="true">
  <div class="brand-video-inner">
    <video
      class="brand-video-media"
      autoplay
      muted
      loop
      playsinline
      webkit-playsinline
      preload="metadata"
      width="1280"
      height="720"
      poster={BASE + 'logo-3d-rotating-poster.jpg'}
    >
      <source src={BASE + 'logo-3d-rotating.mp4'} type="video/mp4" />
    </video>
    <img
      class="brand-video-still"
      src={BASE + 'logo-3d-rotating-poster.jpg'}
      alt="Bygg & Projektgruppen"
      width="1280"
      height="720"
    />
  </div>
</section>

<style>
  .brand-video {
    /* Videons uppmätta bakgrundston (#d4d4d4) bakom videon så fade-zonen smälter
       ihop, tonande till paper (#F7F5F1) nedåt. Mörk hero ovanför som avsiktlig
       kontrast. */
    background: linear-gradient(to bottom, #d4d4d4 0%, #d4d4d4 62%, #F7F5F1 100%);
    padding: clamp(3.5rem, 8vw, 7rem) 1.5rem;
    display: flex;
    justify-content: center;
  }
  .brand-video-inner {
    width: 100%;
    max-width: clamp(320px, 78vw, 900px);
    margin: 0 auto;
  }
  .brand-video-media,
  .brand-video-still {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    /* Rejäl mjuk vinjett: helt opak över loggan (centralt), tonar till transparent
       långt innanför kanterna -> döljer vattenstämpeln (nedre höger) och löser upp
       rektangeln. Radie verifierad mot flera rotationsframes så loggan aldrig
       beskärs i någon vinkel. */
    -webkit-mask-image: radial-gradient(ellipse 47% 60% at 50% 47%, #000 60%, rgba(0, 0, 0, 0) 90%);
    mask-image: radial-gradient(ellipse 47% 60% at 50% 47%, #000 60%, rgba(0, 0, 0, 0) 90%);
  }
  /* Som standard: visa videon, dölj stillbilden. */
  .brand-video-still {
    display: none;
  }
  /* Reducerad rörelse: dölj videon, visa stillbilden. */
  @media (prefers-reduced-motion: reduce) {
    .brand-video-media {
      display: none;
    }
    .brand-video-still {
      display: block;
    }
  }
  @media (max-width: 600px) {
    .brand-video {
      padding-left: 1.1rem;
      padding-right: 1.1rem;
    }
    .brand-video-inner {
      max-width: 90vw;
    }
  }
</style>
